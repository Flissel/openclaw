# Hotel Concierge - Environment Configuration
# Copy to .env.hotel and fill in values

# Gateway authentication token (required - generate a secure random string)
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-secure-token

# Ports (defaults shown)
OPENCLAW_GATEWAY_PORT=18789
QDRANT_PORT=6333
OLLAMA_PORT=11434

# Timezone
TZ=Europe/Berlin
