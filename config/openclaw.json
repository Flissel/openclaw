{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-04-11T17:46:22.732Z"
  },
  "browser": {
    "executablePath": "/usr/local/bin/chromium",
    "noSandbox": true
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "claude",
    "allowedAgents": [
      "claude",
      "codex",
      "kilo"
    ],
    "maxConcurrentSessions": 8
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-7"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "plugins": {
    "entries": {
      "acpx": {
        "enabled": true,
        "config": {
          "mcpServers": {
            "openfang": {
              "command": "python3",
              "args": [
                "/home/node/.openclaw/mcp_stdio_bridge.py"
              ],
              "env": {
                "OPENFANG_MCP_URL": "http://host.docker.internal:4200/mcp"
              }
            }
          }
        }
      }
    }
  }
}
